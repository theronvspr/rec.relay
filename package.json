{
  "name": "rec.relay",
  "version": "3.2.0",
  "description": "Record on mobile, land on PC, over LAN. WebRTC peer-to-peer video relay.",
  "main": "main.js",
  "type": "module",
  "bin": {
    "rec-relay": "./bin/cli.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron:start": "electron .",
    "electron:build": "electron-builder --win --publish always"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "nodemon": "^3.0.1"
  },
  "build": {
    "appId": "com.theronvspr.recrelay",
    "productName": "rec.relay",
    "publish": {
      "provider": "github",
      "owner": "theronvspr",
      "repo": "rec.relay"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "package.json",
      "main.js",
      "server.js",
      "bin/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    }
  }
}
